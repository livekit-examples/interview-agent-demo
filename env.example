#  (Required) Simplismart API Key - get from https://docs.simplismart.ai/model-suite/settings/api-keys
SIMPLISMART_API_KEY=

# Per-service Simplismart endpoints. Defaults in interview_agent.py point at the
# currently-deployed cluster; override here to pin a different deployment.
#STT_URL=
#STT_MODEL=openai/whisper-large-v3-turbo

#LLM_URL=
#LLM_MODEL=google/gemma-3-4b-it

# TTS uses the OpenAI-compatible /v1/audio/speech endpoint.
#TTS_URL=
#TTS_MODEL=qwen-tts
#TTS_VOICE=Aiden

# Post-call evaluation runs through LiveKit Inference (not Simplismart), so
# the structured JSON + markdown report isn't coupled to the conversational
# model. Default is openai/gpt-4.1-mini. See https://docs.livekit.io/agents/models/llm/
# for other options.
#EVALUATION_LLM_MODEL=openai/gpt-4.1-mini

# (Required) LiveKit credentials - get from https://cloud.livekit.io
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Google Sheets — required, this is where interview results are saved.
# Authenticates as the service account in the JSON key file. Remember to
# share the sheet with the service account's client_email (Editor role).
# Full setup instructions in README.md.
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SHEETS_SPREADSHEET_ID=

