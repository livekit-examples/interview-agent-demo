# Simplismart API Key - get from https://docs.simplismart.ai/model-suite/settings/api-keys
SIMPLISMART_API_KEY=

# Used as the root for STT (/predict), TTS (/tts), and the OpenAI-compatible
# LLM (/chat/completions). Defaults to https://api.simplismart.live if unset.
SIMPLISMART_BASE_URL=https://api.simplismart.live

# LiveKit credentials - get from https://cloud.livekit.io
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

